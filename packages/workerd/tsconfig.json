{
	"compilerOptions": {
		"target": "ES2022",
		"module": "preserve",
		"moduleResolution": "bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"declaration": true,
		"rootDir": "./src",
		"outDir": "./dist"
	},
	"include": ["src"]
}
