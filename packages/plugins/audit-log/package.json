{
	"name": "@emdash-cms/plugin-audit-log",
	"version": "0.2.0",
	"description": "Audit logging plugin for EmDash CMS - tracks content changes",
	"type": "module",
	"main": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": "./dist/plugin.mjs"
	},
	"files": [
		"dist",
		"emdash-plugin.jsonc"
	],
	"keywords": [
		"emdash",
		"cms",
		"plugin",
		"audit",
		"logging",
		"history"
	],
	"author": "Matt Kane",
	"license": "MIT",
	"peerDependencies": {
		"emdash": "workspace:>=0.15.0"
	},
	"devDependencies": {
		"@emdash-cms/plugin-cli": "workspace:*",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"scripts": {
		"build": "node node_modules/@emdash-cms/plugin-cli/dist/index.mjs build",
		"dev": "emdash-plugin dev",
		"typecheck": "tsgo --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/emdash-cms/emdash.git",
		"directory": "packages/plugins/audit-log"
	}
}
